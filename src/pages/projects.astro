---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: 'Vemgram',
    url: 'https://vemgram.com',
    description:
      "A B2B platform that connects Indian manufacturers and factories with retailers, exporters, and bulk buyers. Verified profiles with GST, PAN, and MSME badges help buyers source directly from the factories powering India's growth.",
  },
  {
    name: 'SharePDF',
    url: 'https://sharepdf.app',
    description:
      "Upload a PDF, get an instant shareable link, and track who's viewing it. Built-in analytics show view counts, geography, and referrers - no sign-up needed for viewers. Supports custom URLs, password protection, and download controls.",
  },
  {
    name: 'EternalQR',
    url: 'https://eternalqr.app',
    description:
      'Dynamic QR codes that never expire - even if you cancel your plan. Change the destination link anytime without reprinting the code. Includes scan analytics, custom branding, and support for URLs, vCards, Wi-Fi, and more.',
  },
  {
    name: 'Hitbik',
    url: 'https://web.archive.org/web/20161228221543/http://hitbik.com/',
    status: 'acquired',
    description:
      'A rental platform that helped people find homes without brokers or hefty brokerage fees. It was built to make house-hunting more convenient and affordable.',
  },
];
---

<BaseLayout
  title="Projects"
  description="Things I've built - tools and platforms for manufacturers, document sharing, and QR codes."
>
  <section class="projects-page section">
    <div class="container content-width">
      <header class="page-header">
        <p class="section-title">Projects</p>
        <h1>Things I've built</h1>
      </header>

      <div class="projects-content">
        {projects.map((project, i) => (
          <div class="project">
            <span class="project-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="project-heading">
              <h2><a href={project.url} target="_blank" rel="noopener">{project.name}</a></h2>
              {project.status && (
                <span class:list={['project-status', `project-status-${project.status}`]}>
                  {project.status}
                </span>
              )}
            </div>
            <p>{project.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-xl);
  }

  .page-header h1 {
    margin-top: 0.25rem;
  }

  .projects-content {
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .project {
    margin-bottom: var(--space-xl);
  }

  .project:last-child {
    margin-bottom: 0;
  }

  .project-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-tertiary);
    margin-bottom: 0.25rem;
  }

  .project h2 {
    margin: 0;
  }

  .project-heading {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    flex-wrap: wrap;
    margin: 0 0 var(--space-sm) 0;
  }

  .project-heading h2 {
    display: inline;
  }

  .project h2 a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    transition: text-decoration-color var(--transition);
  }

  .project h2 a:hover {
    text-decoration-color: var(--color-accent);
  }

  .project p {
    color: var(--color-text-secondary);
    margin: 0;
  }

  .project-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    vertical-align: middle;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1;
    padding: 0.3rem 0.55rem;
    border-radius: var(--radius-pill);
  }

  .project-status-acquired {
    color: #6a1b9a;
    background: #f3e5f5;
  }
</style>
