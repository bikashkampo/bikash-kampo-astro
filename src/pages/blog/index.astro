---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = ['All', ...new Set(posts.map(p => p.data.category))];
---

<BaseLayout
  title="Blog"
  description="Thoughts on marketing, business strategy, technology, and life by Bikash Kampo."
>
  <section class="blog-page section">
    <div class="container wide-width">
      <header class="page-header">
        <h1>Blog</h1>
        <p class="page-subtitle">Writing about marketing, business, and things I find interesting.</p>
      </header>

      <div class="category-filter" id="category-filter">
        {categories.map(cat => (
          <button
            class:list={['filter-btn', { active: cat === 'All' }]}
            data-filter={cat}
          >
            {cat}
          </button>
        ))}
      </div>

      <div class="posts-list" id="posts-list">
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-xl);
  }

  .page-header h1 {
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .category-filter {
    display: flex;
    gap: 0.5rem;
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }

  .filter-btn {
    background: none;
    border: 1px solid var(--color-border);
    padding: 0.375rem 1rem;
    border-radius: 100px;
    font-size: 0.8125rem;
    font-family: var(--font-body);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all var(--transition);
  }

  .filter-btn:hover {
    border-color: var(--color-text-secondary);
    color: var(--color-text);
  }

  .filter-btn.active {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  .posts-list {
    max-width: var(--content-width);
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.blog-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;

      cards.forEach(card => {
        if (filter === 'All' || card.dataset.category === filter) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
