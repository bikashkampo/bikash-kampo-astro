---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';

function getReadingTime(body?: string): number {
  const wordCount = body?.trim().split(/\s+/).length ?? 250;
  return Math.max(1, Math.ceil(wordCount / 200));
}

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<BaseLayout
  title="Bikash Kampo"
  description="Marketing professional writing about marketing, business strategy, and building things on the internet. Working at Vempus and running UntalkedSEO."
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container content-width">
      <div class="hero-content">
        <p class="hero-greeting">Hey, I'm Bikash</p>
        <h1 class="hero-title">I write about marketing, business, and building things on the internet.</h1>
        <p class="hero-subtitle">I work on marketing at <a href="https://vempus.com" target="_blank" rel="noopener noreferrer">Vempus</a> and run a programmatic SEO project called <a href="https://untalkedseo.com" target="_blank" rel="noopener noreferrer">UntalkedSEO</a>. This is where I share what I'm learning.</p>
        <div class="hero-actions">
          <a href="/blog" class="hero-cta">Read my writing &rarr;</a>
          <a href="/about" class="hero-cta-secondary">About me</a>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about section">
    <div class="container content-width">
      <p class="section-title">A little about me</p>
      <div class="about-grid">
        <div class="about-text">
          <p>I grew up in Koraput, a small town in Odisha. Cricket was my thing growing up, but I started a small business in 2015 and got into marketing the following year.</p>
          <p>I like how marketing sits at the intersection of psychology and data &mdash; figuring out why people buy things, what makes a product stick, and how ideas spread.</p>
          <p>These days I work on marketing at <a href="https://vempus.com" target="_blank" rel="noopener">Vempus</a> and build SEO tools at <a href="https://untalkedseo.com" target="_blank" rel="noopener">UntalkedSEO</a>.</p>
          <a href="/about" class="text-link">More about my journey &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Posts -->
  <section class="featured section">
    <div class="container content-width">
      <p class="section-title">Latest writing</p>
      <div class="featured-posts">
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            readingTime={getReadingTime(post.body)}
          />
        ))}
      </div>
      <a href="/blog" class="view-all">View all posts &rarr;</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: var(--space-2xl) 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .hero-content {
  }

  .hero-greeting {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .hero-greeting::before {
    content: '';
    display: block;
    width: 20px;
    height: 1.5px;
    background: currentColor;
    flex-shrink: 0;
  }

  .hero-title {
    font-size: 2.75rem;
    line-height: 1.15;
    margin-bottom: var(--space-lg);
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
  }

  .hero-subtitle a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    transition: text-decoration-color var(--transition);
  }

  .hero-subtitle a:hover {
    text-decoration-color: var(--color-accent);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .hero-cta {
    display: inline-block;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-bg);
    background: var(--color-text);
    text-decoration: none;
    padding: 0.625rem 1.5rem;
    border: 1px solid var(--color-text);
    border-radius: var(--radius-md);
    transition: all var(--transition);
  }

  .hero-cta:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .hero-cta-secondary {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .hero-cta-secondary:hover {
    color: var(--color-text);
  }

  /* About */
  .about-text p {
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .about-text a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    transition: text-decoration-color var(--transition);
  }

  .about-text a:hover {
    text-decoration-color: var(--color-accent);
  }

  .text-link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity var(--transition);
  }

  .text-link:hover {
    opacity: 0.7;
  }

  /* Featured */
  .view-all {
    display: inline-block;
    margin-top: var(--space-lg);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity var(--transition);
  }

  .view-all:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2rem;
    }

  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 1.625rem;
    }
  }
</style>
