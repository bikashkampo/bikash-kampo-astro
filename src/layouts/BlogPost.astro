---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  image?: { url: string; alt: string };
  readingTime?: number;
}

const { title, description, pubDate, updatedDate, category, image, readingTime = 5 } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalUrl = Astro.url.href;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "url": canonicalUrl,
  "datePublished": pubDate.toISOString(),
  ...(updatedDate && { "dateModified": updatedDate.toISOString() }),
  ...(image && { "image": image.url }),
  "author": {
    "@type": "Person",
    "name": "Bikash Kampo",
    "url": "https://bikashkampo.com"
  },
  "publisher": {
    "@type": "Person",
    "name": "Bikash Kampo",
    "url": "https://bikashkampo.com"
  }
};
---

<BaseLayout
  title={title}
  description={description}
  image={image?.url}
  imageAlt={image?.alt}
  type="article"
  publishedDate={pubDate}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  </Fragment>
  <article class="article">
    <header class="article-header container content-width">
      <div class="article-meta">
        <span class="article-category">{category}</span>
        <span class="article-separator">&middot;</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <span class="article-separator">&middot;</span>
        <span class="reading-time">{readingTime} min read</span>
      </div>
      <h1>{title}</h1>
      {updatedDate && formattedUpdatedDate && (
        <p class="article-updated">Updated {formattedUpdatedDate}</p>
      )}
    </header>

    <div class="prose container content-width">
      <slot />
    </div>

    <footer class="article-footer container content-width">
      <a href="/blog" class="back-link">&larr; Back to all posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .article {
    padding: var(--space-xl) 0 var(--space-2xl);
  }

  .article-header {
    margin-bottom: var(--space-xl);
  }

  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-md);
  }

  .article-category {
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
    font-size: 0.75rem;
  }

  .reading-time {
    font-size: 0.8125rem;
  }

  .article-header h1 {
    font-size: 2.5rem;
    line-height: 1.2;
    margin-bottom: var(--space-md);
  }

  .article-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 0;
    font-style: italic;
  }

  .article-updated {
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-sm);
    margin-bottom: 0;
  }

  .article-image {
    margin-bottom: var(--space-xl);
  }

  .article-image img {
    width: 100%;
    border-radius: 8px;
  }

  .prose :global(p) {
    margin-bottom: 1.5em;
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .prose :global(h2) {
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    font-size: 1.625rem;
  }

  .prose :global(h3) {
    margin-top: 2em;
    margin-bottom: 0.5em;
    font-size: 1.375rem;
  }

  .prose :global(h4) {
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 2em 0;
  }

  .prose :global(figure) {
    margin: 2em 0;
  }

  .prose :global(figcaption) {
    text-align: center;
    color: var(--color-text-tertiary);
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25em;
    margin: 1.5em 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .prose :global(blockquote p) {
    margin-bottom: 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 1.25em 0;
    padding-left: 1.5em;
  }

  .prose :global(li) {
    margin-bottom: 0.5em;
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .prose :global(code) {
    background: var(--color-bg-secondary);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .prose :global(pre) {
    background: #1a1a2e;
    color: #e0e0e0;
    padding: 1.25em;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5em 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: 0.875rem;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    transition: text-decoration-color var(--transition);
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  .prose :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5em 0;
  }

  .article-footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .article-header h1 {
      font-size: 1.75rem;
    }

    .prose :global(p),
    .prose :global(li) {
      font-size: 1rem;
    }
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    margin: 1.75em 0;
  }

  .prose :global(th) {
    background: var(--color-bg-secondary);
    color: var(--color-text);
    font-weight: 600;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.75em 1em;
    text-align: left;
    border: 1px solid var(--color-border);
  }

  .prose :global(td) {
    padding: 0.7em 1em;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .prose :global(tr:nth-child(even) td) {
    background: var(--color-bg-secondary);
  }

  .prose :global(tr:hover td) {
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
  }

  /* Horizontal scroll on mobile */
  .prose :global(table) {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

</style>
