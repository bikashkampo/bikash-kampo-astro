---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/fonts.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
}

const { title, description, image, imageAlt, type, publishedDate } = Astro.props;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Bikash Kampo",
  "url": "https://bikashkampo.com",
  "sameAs": [
    "https://twitter.com/bablukampo",
    "https://www.linkedin.com/in/bikashkampo/"
  ],
  "jobTitle": "Marketing Professional",
  "description": "Writing about marketing, business, and building things on the internet."
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/blog/profile.png" />
    <link rel="apple-touch-icon" href="/images/blog/profile.png" />
    <link rel="alternate" type="application/rss+xml" title="Bikash Kampo" href="/rss.xml" />
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/source-serif-4-latin.woff2" as="font" type="font/woff2" crossorigin />
    <SEO
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      type={type}
      publishedDate={publishedDate}
    />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      if (window.location.hash.includes('invite_token') || window.location.hash.includes('confirmation_token') || window.location.hash.includes('recovery_token')) {
        var s = document.createElement('script');
        s.src = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
        s.onload = function() {
          if (window.netlifyIdentity) {
            window.netlifyIdentity.on("login", function() {
              document.location.href = "/admin/";
            });
          }
        };
        document.head.appendChild(s);
      }
    </script>
  </body>
</html>
