---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/fonts.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
}

const { title, description, image, imageAlt, type, publishedDate } = Astro.props;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Bikash Kampo",
  "url": "https://bikashkampo.com",
  "sameAs": [
    "https://twitter.com/bablukampo",
    "https://www.linkedin.com/in/bikashkampo/"
  ],
  "jobTitle": "Marketing Professional",
  "description": "Writing about marketing, business, and building things on the internet."
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/png" href="/images/blog/profile.png" />
    <link rel="apple-touch-icon" href="/images/blog/profile.png" />
    <link rel="alternate" type="application/rss+xml" title="Bikash Kampo" href="/rss.xml" />
    <link rel="me" href="https://twitter.com/bablukampo" />
    <link rel="me" href="https://www.linkedin.com/in/bikashkampo/" />
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/source-serif-4-latin.woff2" as="font" type="font/woff2" crossorigin />
    <SEO
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      type={type}
      publishedDate={publishedDate}
    />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.github.com; frame-src 'self' https://www.youtube.com https://platform.twitter.com;" />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
