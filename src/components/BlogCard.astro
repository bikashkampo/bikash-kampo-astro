---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  slug: string;
  readingTime?: number;
}

const { title, description, pubDate, category, slug, readingTime } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="blog-card" data-category={category}>
  <div class="card-meta">
    <span class="card-category">{category}</span>
    <span class="card-separator">&middot;</span>
    <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    {readingTime && (
      <>
        <span class="card-separator">&middot;</span>
        <span class="card-reading-time">{readingTime} min read</span>
      </>
    )}
  </div>
  <h3 class="card-title">{title}</h3>
  <p class="card-description">{description}</p>
</a>

<style>
  .blog-card {
    display: block;
    padding: var(--space-lg) 0;
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-light);
  }

  .blog-card:last-child {
    border-bottom: none;
  }

  .card-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    margin-bottom: 0.5rem;
  }

  .card-category {
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
    font-size: 0.6875rem;
  }

  .card-reading-time {
    font-size: 0.75rem;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.375rem;
    line-height: 1.4;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--transition), color var(--transition);
  }

  .blog-card:hover .card-title {
    text-decoration-color: var(--color-accent);
    color: var(--color-accent);
  }

  .card-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
